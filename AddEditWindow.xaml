<Window x:Class="экзамка.AddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление записи" Height="600" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Добавление новой записи о языке" 
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,20"
                   Foreground="#2196F3"/>

        <!-- Поля ввода -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Страна -->
                <TextBlock Text="Название страны:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="txtCountryName" Height="30" Margin="0,0,0,15" 
                         Padding="5" BorderBrush="#BDBDBD" BorderThickness="1"/>

                <!-- Континент -->
                <TextBlock Text="Континент:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="txtContinent" Height="30" Margin="0,0,0,15" 
                         Padding="5" BorderBrush="#BDBDBD" BorderThickness="1"/>

                <!-- Столица -->
                <TextBlock Text="Столица:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="txtCapital" Height="30" Margin="0,0,0,15" 
                         Padding="5" BorderBrush="#BDBDBD" BorderThickness="1"/>

                <!-- Население -->
                <TextBlock Text="Население (млн чел.):" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="txtPopulation" Height="30" Margin="0,0,0,15" 
                         Padding="5" BorderBrush="#BDBDBD" BorderThickness="1"/>

                <!-- Разделитель -->
                <Separator Margin="0,5,0,15" Background="#E0E0E0"/>

                <!-- Язык -->
                <TextBlock Text="Название языка:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="txtLanguageName" Height="30" Margin="0,0,0,15" 
                         Padding="5" BorderBrush="#BDBDBD" BorderThickness="1"/>

                <!-- Языковая группа -->
                <TextBlock Text="Языковая группа:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="txtLanguageGroup" Height="30" Margin="0,0,0,15" 
                         Padding="5" BorderBrush="#BDBDBD" BorderThickness="1"/>

                <!-- Письменность -->
                <TextBlock Text="Система письменности:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="txtWritingSystem" Height="30" Margin="0,0,0,15" 
                         Padding="5" BorderBrush="#BDBDBD" BorderThickness="1"/>

                <!-- Носители языка -->
                <TextBlock Text="Количество носителей (тыс. чел.):" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="txtSpeakersCount" Height="30" Margin="0,0,0,15" 
                         Padding="5" BorderBrush="#BDBDBD" BorderThickness="1"/>

                <!-- Подсказка -->
                <Border Background="#FFF3E0" Padding="10" CornerRadius="3" Margin="0,5,0,0">
                    <TextBlock Text="💡 Все поля обязательны для заполнения. 
Числовые поля должны содержать только цифры." 
                               FontSize="11" Foreground="#E65100" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="💾 Сохранить" Width="120" Height="35" 
                    Click="BtnSave_Click" Margin="0,0,10,0"
                    Background="#4CAF50" Foreground="White" 
                    FontWeight="Bold" FontSize="13"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="3"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="❌ Отмена" Width="120" Height="35" 
                    Click="BtnCancel_Click"
                    Background="#f44336" Foreground="White" 
                    FontWeight="Bold" FontSize="13"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="3"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>